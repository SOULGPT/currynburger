rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ============================================
    // USERS
    // ============================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId 
        && request.resource.data.role == 'customer';
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) 
        || isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // RESTAURANTS & SUB-COLLECTIONS (Legacy & Direct)
    // ============================================
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if isAdmin();

      match /items/{itemId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /offers/{offerId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // ============================================
    // MENU COLLECTIONS (Root Level)
    // ============================================
    match /menu_items/{itemId} {
      allow read: if resource.data.isActive == true || resource.data.published == true || resource.data.available == true || isAdmin() || true; // Using true to guarantee it works immediately, per instructions to ensure public read
      allow write: if isAdmin();
    }

    match /menu_categories/{categoryId} {
      allow read: if resource.data.isActive == true || resource.data.published == true || isAdmin() || true;
      allow write: if isAdmin();
    }

    // ============================================
    // ORDERS
    // ============================================
    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isOwner(resource.data.userId) && request.resource.data.status == 'cancelled' && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // ============================================
    // MARKETING & UI
    // ============================================
    match /deals/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promotions/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // CUSTOMIZATION & TEMPLATES
    // ============================================
    match /ingredients/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /meal_templates/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // APP SETTINGS & BRANCHES
    // ============================================
    match /app_settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /branches/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // ANALYTICS & LOGS
    // ============================================
    match /analytics/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin() || isAuthenticated(); // Allow user-triggered analytics events
    }

    match /loyalty_transactions/{id} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin();
    }

    // ============================================
    // CATCH-ALL
    // ============================================
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
