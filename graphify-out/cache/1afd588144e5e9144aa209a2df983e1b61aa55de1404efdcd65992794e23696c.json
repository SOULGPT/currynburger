ts", "source_location": "L64"}, {"caller_nid": "firebase_coupons_subscribetocoupons", "callee": "(async () => {\n    try {\n      const db = await getFirebaseDb()\n      if (!db) return\n\n      const { collection, onSnapshot } = await import(\"firebase/firestore\")\n      const couponsRef = collection(db, \"coupons\")\n\n      unsubscribe = onSnapshot(\n        couponsRef,\n        (snapshot) => {\n          const coupons = snapshot.docs.map((doc) => ({\n            id: doc.id,\n            ...doc.data(),\n            validFrom: doc.data().validFrom?.toDate() || new Date(),\n            validTo: doc.data().validTo?.toDate() || new Date(),\n          })) as Coupon[]\n          if (coupons.length > 0) callback(coupons)\n        },\n        (error: any) => {\n          if (error.code === \"permission-denied\") switchToLocalMode()\n        },\n      )\n    } catch {}\n  })", "source_file": "/Users/miruzaankhan/Documents/curryandburger/lib/firebase-coupons.ts", "source_location": "L71"}, {"caller_nid": "firebase_coupons_addcoupon", "callee": "now", "source_file": "/Users/miruzaankhan/Documents/curryandburger/lib/firebase-coupons.ts", "source_location": "L104"}, {"caller_nid": "firebase_coupons_addcoupon", "callee": "push", "source_file": "/Users/miruzaankhan/Documents/curryandburger/lib/firebase-coupons.ts", "source_location": "L106"}, {"caller_nid": "firebase_coupons_addcoupon", "callee": "getFirebaseDb", "source_file": "/Users/miruzaankhan/Documents/curryandburger/lib/firebase-coupons.ts", "source_location": "L110"}, {"caller_nid": "firebase_coupons_addcoupon", "callee": "import", "source_file": "/Users/miruzaankhan/Documents/curryandburger/lib/firebase-coupons.ts", "source_location": "L112"}, {"caller_nid": "firebase_coupons_addcoupon", "callee": "addDoc", "source_file": "/Users/miruzaankhan/Documents/curryandburger/lib/firebase-coupons.ts", "source_location": "L113"}, {"caller_nid": "firebase_coupons_addcoupon", "callee": "collection", "source_file": "/Users/miruzaa