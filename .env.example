# =============================================
# CURRY & BURGER - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# =============================================

# =============================================
# SUPABASE CONFIGURATION (Primary Database)
# =============================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-anon-public-key-here

# =============================================
# APPWRITE CONFIGURATION (Legacy/Backup)
# =============================================
# Get these from: https://cloud.appwrite.io/console/project/YOUR_PROJECT/settings
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=your-appwrite-project-id

# =============================================
# SENTRY ERROR TRACKING (Optional)
# =============================================
# Get this from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
# Leave empty to disable error tracking
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================
# GOOGLE OAUTH (For Social Login)
# =============================================
# Get these from: https://console.cloud.google.com/apis/credentials
# Required for Google Sign-In functionality
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# =============================================
# APPLE SIGN-IN (For iOS Social Login)
# =============================================
# Get these from: https://developer.apple.com/account/resources/identifiers
# Required for Apple Sign-In on iOS
EXPO_PUBLIC_APPLE_CLIENT_ID=com.curryandburger.app
EXPO_PUBLIC_APPLE_REDIRECT_URI=https://your-domain.com/auth/callback

# =============================================
# PAYMENT PROCESSING (Future Feature)
# =============================================
# Stripe Configuration (when implementing payments)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret

# =============================================
# ANALYTICS & TRACKING (Optional)
# =============================================
# Google Analytics (for web version)
EXPO_PUBLIC_GA_TRACKING_ID=GA_MEASUREMENT_ID

# Mixpanel (for advanced analytics)
EXPO_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# =============================================
# PUSH NOTIFICATIONS (Future Feature)
# =============================================
# Expo Push Notifications
EXPO_PUBLIC_EXPO_ACCESS_TOKEN=your-expo-access-token

# Firebase Cloud Messaging (Android)
EXPO_PUBLIC_FCM_SERVER_KEY=your-fcm-server-key

# Apple Push Notification Service (iOS)
EXPO_PUBLIC_APNS_CERTIFICATE_PATH=path/to/apns/certificate
EXPO_PUBLIC_APNS_KEY_ID=your-key-id
EXPO_PUBLIC_APNS_TEAM_ID=your-team-id

# =============================================
# EXTERNAL APIs (Optional Features)
# =============================================
# Google Maps API (for delivery tracking)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# OpenWeather API (for weather-based recommendations)
EXPO_PUBLIC_OPENWEATHER_API_KEY=your-openweather-api-key

# SendGrid (for email notifications)
SENDGRID_API_KEY=your-sendgrid-api-key
EXPO_PUBLIC_SENDGRID_FROM_EMAIL=noreply@curryandburger.com

# =============================================
# DEVELOPMENT SETTINGS
# =============================================
# Set to 'true' for development mode
EXPO_PUBLIC_DEV_MODE=false

# API timeout in milliseconds
EXPO_PUBLIC_API_TIMEOUT=30000

# Enable/disable features
EXPO_PUBLIC_ENABLE_SOCIAL_AUTH=true
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=false
EXPO_PUBLIC_ENABLE_ANALYTICS=false

# =============================================
# BUILD & DEPLOYMENT
# =============================================
# EAS Build Configuration
EXPO_PUBLIC_APP_ENV=production
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_BUILD_NUMBER=1

# =============================================
# SECURITY & ENCRYPTION
# =============================================
# JWT Secret (for custom authentication if needed)
JWT_SECRET=your-jwt-secret-key

# Encryption keys (for sensitive data)
ENCRYPTION_KEY=your-32-character-encryption-key

# =============================================
# DATABASE CONNECTIONS (Advanced)
# =============================================
# PostgreSQL direct connection (if needed for custom queries)
DATABASE_URL=postgresql://user:password@host:port/database

# Redis (for caching and sessions)
REDIS_URL=redis://localhost:6379

# =============================================
# THIRD-PARTY INTEGRATIONS
# =============================================
# Slack Webhook (for order notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Discord Webhook (alternative notifications)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# =============================================
# CONTENT MANAGEMENT
# =============================================
# Contentful CMS (for dynamic content)
EXPO_PUBLIC_CONTENTFUL_SPACE_ID=your-space-id
EXPO_PUBLIC_CONTENTFUL_ACCESS_TOKEN=your-access-token

# =============================================
# MONITORING & LOGGING
# =============================================
# LogRocket (for session replay)
EXPO_PUBLIC_LOGROCKET_APP_ID=your-logrocket-app-id

# DataDog (for advanced monitoring)
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key

# =============================================
# CDN & MEDIA STORAGE
# =============================================
# Cloudinary (for image optimization)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
EXPO_PUBLIC_CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# AWS S3 (alternative media storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1

# =============================================
# RATE LIMITING & SECURITY
# =============================================
# Rate limiting configuration
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_LIMIT=10

# CORS settings (for web version)
CORS_ORIGIN=https://curryandburger.com

# =============================================
# FEATURE FLAGS
# =============================================
# Enable/disable experimental features
EXPO_PUBLIC_ENABLE_DARK_MODE=false
EXPO_PUBLIC_ENABLE_MULTILANGUAGE=false
EXPO_PUBLIC_ENABLE_LOYALTY_PROGRAM=true
EXPO_PUBLIC_ENABLE_RESERVATIONS=false
EXPO_PUBLIC_ENABLE_DELIVERY_TRACKING=false

# =============================================
# SUPPORT & HELP
# =============================================
# Support contact information
EXPO_PUBLIC_SUPPORT_EMAIL=support@curryandburger.com
EXPO_PUBLIC_SUPPORT_PHONE=+1-555-CURRY

# =============================================
# LEGAL & COMPLIANCE
# =============================================
# Privacy policy and terms URLs
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://curryandburger.com/privacy
EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://curryandburger.com/terms

# GDPR compliance
EXPO_PUBLIC_GDPR_ENABLED=true
EXPO_PUBLIC_COOKIE_CONSENT_REQUIRED=true

# =============================================
# PERFORMANCE & OPTIMIZATION
# =============================================
# Image optimization settings
EXPO_PUBLIC_IMAGE_QUALITY=80
EXPO_PUBLIC_IMAGE_MAX_WIDTH=1200
EXPO_PUBLIC_IMAGE_MAX_HEIGHT=1200

# Caching settings
EXPO_PUBLIC_CACHE_TTL=3600000
EXPO_PUBLIC_CACHE_MAX_SIZE=50

# =============================================
# TESTING & QA
# =============================================
# Test environment settings
EXPO_PUBLIC_TEST_MODE=false
EXPO_PUBLIC_MOCK_API_RESPONSES=false

# =============================================
# BACKUP & RECOVERY
# =============================================
# Backup settings
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=daily

# =============================================
# END OF CONFIGURATION
# =============================================
# Note: Never commit the actual .env file to version control
# Only commit this .env.example file