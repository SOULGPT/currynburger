rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function under5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // Menu and Category Images
    match /menu-images/{imageId} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && under5MB();
      allow delete: if isAdmin();
    }

    match /category-images/{imageId} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && under5MB();
      allow delete: if isAdmin();
    }

    // Promotions and Banners
    match /promotion-images/{imageId} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && under5MB();
      allow delete: if isAdmin();
    }

    match /banner-images/{imageId} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && under5MB();
      allow delete: if isAdmin();
    }

    // Restaurant Assets (Logos, etc.)
    match /restaurant-assets/{assetId} {
      allow read: if true;
      allow write: if isAdmin() && under5MB();
      allow delete: if isAdmin();
    }

    // User Profile Pictures
    match /user-avatars/{userId}/{imageId} {
      allow read: if true;
      allow write: if request.auth.uid == userId && isImage() && under5MB();
      allow delete: if request.auth.uid == userId || isAdmin();
    }

    // Catch-all
    match /{allPaths=**} {
      allow read: if true; // Most assets in a restaurant app should be public
      allow write: if isAdmin();
    }
  }
}
